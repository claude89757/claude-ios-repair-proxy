[Unit]
Description=Claude iOS repair mitmproxy
After=network-online.target claude-repair-status.service
Wants=network-online.target

[Service]
WorkingDirectory=/opt/claude-ios-repair
Environment=PYTHONUNBUFFERED=1
Environment=REPAIR_STATUS_URL=http://127.0.0.1:9000/api/internal/events
EnvironmentFile=-/etc/claude-repair/app.env
ExecStartPre=/usr/bin/mkdir -p /opt/claude-ios-repair/mitmproxy
ExecStartPre=/usr/bin/mkdir -p /opt/claude-ios-repair/data
ExecStartPre=-/usr/bin/docker rm -f claude-repair-mitm
ExecStart=/bin/sh -lc 'exec /usr/bin/docker run --rm --name claude-repair-mitm --network host --env-file /etc/claude-repair/app.env -e PYTHONUNBUFFERED=1 -e PYTHONPATH=/opt/claude-ios-repair -e REPAIR_STATUS_URL="$REPAIR_STATUS_URL" -v /opt/claude-ios-repair/mitmproxy:/root/.mitmproxy -v /opt/claude-ios-repair/data:/opt/claude-ios-repair/data claude-ios-repair:latest python -m repair_site.mitm.port_supervisor'
ExecStop=/usr/bin/docker stop claude-repair-mitm
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
